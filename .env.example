# Coordinator configuration (defaults match docker-compose.yml — copy to .env
# or export in the shell; every variable is optional).

# Postgres main database
DATABASE_URL=postgres://orchestrator:orchestrator@127.0.0.1:5432/orchestrator

# Redis cache (worker registry + ready-job queue)
REDIS_URL=redis://127.0.0.1:6379

# Forgejo token for private repos (public repos need none)
#FORGEJO_TOKEN=

# yaml-parser location + python used to run it
#YAML_PARSER_DIR=yaml-parser
#YAML_PARSER_PYTHON=yaml-parser/.venv/bin/python
